> 
> ### Name: build_progression
> ### Title: Build Chord Progression
> ### Aliases: build_progression
> 
> ### ** Examples
> 
> build_progression("C4", "minor")
$C4minor
[1] "C4"  "Eb4" "G4" 

$D4diminished
[1] "D4"  "F4"  "Ab4"

$Eb4major
[1] "Eb4" "G4"  "Bb4"

$F4minor
[1] "F4"  "Ab4" "C5" 

$G4minor
[1] "G4"  "Bb4" "D5" 

$Ab4major
[1] "Ab4" "C5"  "Eb5"

$Bb4major
[1] "Bb4" "D5"  "F5" 

$C5minor
[1] "C5"  "Eb5" "G5" 

> build_progression("Bb4", "major")
$Bb4major
[1] "Bb4" "D5"  "F5" 

$C5minor
[1] "C5"  "Eb5" "G5" 

$D5minor
[1] "D5" "F5" "A5"

$Eb5major
[1] "Eb5" "G5"  "Bb5"

$F5major
[1] "F5" "A5" "C6"

$G5minor
[1] "G5"  "Bb5" "D6" 

$A5diminished
[1] "A5"  "C6"  "Eb6"

$Bb5major
[1] "Bb5" "D6"  "F6" 

> ## Not run: 
> ##D build_progression("Bb4", "major", play = TRUE, plot = TRUE)
