> # music-tests.R
> # ::music::
> # 2019- EDG rtemis.org
> 
> library(music)
  .:music v0.2.0 🎧 Welcome, sdg
> is_macos <- length(grep("darwin", sessionInfo()$platform)) == 1
> 
> # note2freq ----
> freq <- note2freq(note = "A4")
> 
> # freq2wave ----
> wave <- freq2wave(
+   frequency = freq,
+   plot = TRUE,
+   duration = .1,
+   attack.time = 5,
+   inner.release.time = 5
+ )
> 
